# .env
## Supabase
NEXT_PUBLIC_SUPABASE_URL=去supabase dashboard 看
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=去supabase dashboard 看


## TapPay
NEXT_PUBLIC_TAPPAY_APP_ID=去 tappay dashboard 看
NEXT_PUBLIC_TAPPAY_APP_KEY=去 tappay dashboard 看
NEXT_PUBLIC_TAPPAY_SERVER_TYPE=sandbox
# Checkout 目前使用本地 TapPay sandbox simulator 建立訂單 / 付款紀錄，不真實扣款。
TAPPAY_PARTNER_KEY=去 tappay dashboard 看(公司資訊)
TAPPAY_MERCHANT_ID=去 tappay dashboard 看(商家管理 W_TAPPAY)

# prisma
DATABASE_URL=supabase 後台 connect ORM 有 (5432 port)
DIRECT_URL=supabase 後台 connect ORM 有 (5432 port)

