model PaymentMethod {
  id                      String           @id @default(uuid()) @db.Uuid
  userId                  String           @unique(map: "payment_methods_one_default_per_user_idx", where: raw("(is_default = true)")) @map("user_id") @db.Uuid
  provider                PaymentProvider  @default(tappay)
  providerPaymentMethodId String?          @map("provider_payment_method_id")
  providerCardKey         String?          @map("provider_card_key") @db.VarChar(64)
  providerCardToken       String?          @map("provider_card_token") @db.VarChar(67)
  cardIdentifier          String?          @map("card_identifier")
  brand                   String
  binCode                 String?          @map("bin_code") @db.VarChar(6)
  last4                   String           @db.VarChar(4)
  holder                  String
  billingEmail            String           @map("billing_email")
  expMonth                Int?             @map("exp_month")
  expYear                 Int?             @map("exp_year")
  tappayPrimeState        TapPayPrimeState @default(ready) @map("tappay_prime_state")
  isDefault               Boolean          @default(false) @map("is_default")
  createdAt               DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([userId, createdAt])
  @@index([userId, isDefault])
  @@map("payment_methods")
}
