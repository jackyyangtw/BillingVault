model Subscription {
  id                 String                   @id @default(uuid()) @db.Uuid
  userId             String                   @map("user_id") @db.Uuid
  orderId            String                   @unique @map("order_id") @db.Uuid
  planId             String                   @map("plan_id")
  productId          String                   @map("product_id")
  cycle              String                   @db.VarChar(16)
  status             SubscriptionStatus       @default(active)
  currentPeriodStart DateTime                 @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd   DateTime                 @map("current_period_end") @db.Timestamptz(6)
  createdAt          DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  order              Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  scheduledChanges   SubscriptionPlanChange[]
  items              SubscriptionItem[]

  @@index([userId, status])
  @@index([userId, currentPeriodEnd])
  @@map("subscriptions")
}

model SubscriptionItem {
  id             String       @id @default(uuid()) @db.Uuid
  subscriptionId String       @map("subscription_id") @db.Uuid
  productId      String       @map("product_id")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, productId])
  @@index([subscriptionId])
  @@map("subscription_items")
}

model SubscriptionPlanChange {
  id             String                       @id @default(uuid()) @db.Uuid
  userId         String                       @map("user_id") @db.Uuid
  subscriptionId String                       @map("subscription_id") @db.Uuid
  fromPlanId     String                       @map("from_plan_id")
  toPlanId       String                       @map("to_plan_id")
  fromCycle      String                       @map("from_cycle") @db.VarChar(16)
  toCycle        String                       @map("to_cycle") @db.VarChar(16)
  effectiveAt    DateTime                     @map("effective_at") @db.Timestamptz(6)
  status         SubscriptionPlanChangeStatus @default(pending)
  createdAt      DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                     @updatedAt @map("updated_at") @db.Timestamptz(6)
  subscription   Subscription                 @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, status], map: "subscription_plan_changes_one_pending_per_subscription_idx", where: raw("(status = 'pending')"))
  @@index([userId, status])
  @@index([subscriptionId, status])
  @@index([effectiveAt, status])
  @@map("subscription_plan_changes")
}
